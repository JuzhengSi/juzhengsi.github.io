---
import BaseLayout from "../layouts/BaseLayout.astro";

const introLines = [
  "你好，我叫司居正！",
  "欢迎访问我的博客！",
  "希望在这个博客里，我们可以产生共鸣！",
];
---

<BaseLayout title="主页" description="司居正的个人主页。">
  <div class="landing">
    <canvas id="particles" class="particles" aria-hidden="true"></canvas>

    <div class="content">
      <h1 class="name" aria-label="司居正">
        <span class="char" style="--i:0">司</span><span class="char" style="--i:1">居</span><span class="char" style="--i:2">正</span>
      </h1>

      <p class="romaji">SI &nbsp; JUZHENG</p>

      <div class="typewriter" aria-live="polite">
        <span class="typewriter-text" id="typewriter"></span>
        <span class="typewriter-cursor" aria-hidden="true"></span>
      </div>
      <script type="application/json" id="intro-lines" set:html={JSON.stringify(introLines)} is:inline></script>

      <nav class="cta" aria-label="快捷入口">
        <a href="/blog/" class="cta-link">
          <span class="cta-num">01</span>
          <span class="cta-label">博客</span>
          <span class="cta-arrow">→</span>
        </a>
        <a href="/cv/" class="cta-link">
          <span class="cta-num">02</span>
          <span class="cta-label">简历</span>
          <span class="cta-arrow">→</span>
        </a>
      </nav>

      <div class="scroll-hint" aria-hidden="true">
        <span class="scroll-line"></span>
        <span class="scroll-text">SCROLL</span>
      </div>
    </div>
  </div>
</BaseLayout>

<style is:global>
  body:has(.landing) {
    overflow-x: hidden;
  }
  body:has(.landing) .page {
    width: 100%;
    max-width: none;
    padding: 0;
  }
</style>

<style>
  .landing {
    position: relative;
    min-height: calc(100vh - 180px);
    display: grid;
    place-items: center;
    overflow: hidden;
    margin: 0;
  }

  .particles {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    pointer-events: none;
  }

  .content {
    position: relative;
    z-index: 1;
    width: min(calc(100% - 32px), 880px);
    text-align: center;
    padding: 32px 0 60px;
  }

  /* Name */
  .name {
    margin: 0;
    font-family:
      "Source Han Serif SC", "Noto Serif CJK SC", "Noto Serif SC", "Songti SC", "STSong",
      "Yu Mincho", serif;
    font-weight: 700;
    font-size: clamp(4rem, 12vw, 9rem);
    line-height: 1;
    letter-spacing: 0.08em;
    color: #111;
    display: flex;
    justify-content: center;
    gap: 0.04em;
    user-select: none;
  }

  .name .char {
    display: inline-block;
    opacity: 0;
    transform: translateY(60px) scale(0.92);
    animation: char-rise 1.1s forwards cubic-bezier(0.2, 0.7, 0.2, 1);
    animation-delay: calc(0.4s + var(--i) * 0.18s);
    transition: transform 0.4s ease;
  }

  .name:hover .char {
    transform: translateY(-4px);
  }

  .name .char:hover {
    transform: translateY(-10px) rotate(-2deg);
  }

  /* Romaji subtitle */
  .romaji {
    margin: 26px 0 0;
    color: #6e6c66;
    font-family: "Inter", ui-sans-serif, system-ui, sans-serif;
    font-size: 0.86rem;
    font-weight: 400;
    letter-spacing: 0.5em;
    text-transform: uppercase;
    opacity: 0;
    animation: fade-in 0.9s 1.1s forwards ease-out;
  }

  /* Typewriter intro */
  .typewriter {
    margin: 44px auto 0;
    min-height: 2em;
    color: #1a1a1a;
    font-family:
      "Source Han Serif SC", "Noto Serif CJK SC", "Songti SC", serif;
    font-size: clamp(1rem, 1.6vw, 1.25rem);
    letter-spacing: 0.04em;
    line-height: 1.6;
    opacity: 0;
    animation: fade-in 0.9s 1.4s forwards ease-out;
  }

  .typewriter-text {
    white-space: pre-wrap;
  }

  .typewriter-cursor {
    display: inline-block;
    width: 0.5em;
    height: 1.05em;
    margin-left: 4px;
    vertical-align: -0.15em;
    background: #111;
    animation: blink 1s steps(2) infinite;
  }

  @keyframes blink {
    50% {
      opacity: 0;
    }
  }

  /* CTA */
  .cta {
    display: flex;
    justify-content: center;
    gap: 36px;
    margin: 64px 0 0;
    opacity: 0;
    animation: fade-in 0.9s 1.7s forwards ease-out;
  }

  .cta-link {
    display: inline-flex;
    align-items: baseline;
    gap: 12px;
    padding: 8px 0;
    color: #111;
    font-family:
      "Source Han Serif SC", "Noto Serif CJK SC", "Songti SC", serif;
    font-size: 1rem;
    text-decoration: none;
    border-bottom: 1px solid #111;
    position: relative;
    transition: gap 0.2s ease;
  }

  .cta-num {
    color: #6e6c66;
    font-family: "Inter", ui-sans-serif, system-ui, sans-serif;
    font-size: 0.72rem;
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.1em;
  }

  .cta-arrow {
    font-family: "Inter", ui-sans-serif, system-ui, sans-serif;
    font-size: 0.95rem;
    transition: transform 0.25s ease;
  }

  .cta-link:hover {
    gap: 18px;
  }

  .cta-link:hover .cta-arrow {
    transform: translateX(4px);
  }

  /* Scroll hint */
  .scroll-hint {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    margin: 80px 0 0;
    color: #9a958c;
    font-family: "Inter", ui-sans-serif, system-ui, sans-serif;
    font-size: 0.7rem;
    letter-spacing: 0.4em;
    opacity: 0;
    animation: fade-in 0.9s 2s forwards ease-out;
  }

  .scroll-line {
    width: 1px;
    height: 40px;
    background: linear-gradient(to bottom, transparent, #6e6c66 40%, transparent);
    position: relative;
    overflow: hidden;
  }

  .scroll-line::after {
    content: "";
    position: absolute;
    top: -10px;
    left: 0;
    right: 0;
    height: 10px;
    background: #111;
    animation: scroll-drop 2.4s infinite ease-in-out;
  }

  /* Animations */
  @keyframes fade-in {
    to {
      opacity: 1;
      transform: none;
    }
  }

  @keyframes char-rise {
    to {
      opacity: 1;
      transform: none;
    }
  }

  @keyframes scroll-drop {
    0% {
      top: -10px;
      opacity: 0;
    }
    50% {
      opacity: 1;
    }
    100% {
      top: 40px;
      opacity: 0;
    }
  }

  @media (max-width: 760px) {
    .name {
      font-size: clamp(3.2rem, 16vw, 5.5rem);
    }

    .cta {
      gap: 24px;
      flex-wrap: wrap;
    }

    .scroll-hint {
      margin-top: 56px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .name .char,
    .romaji,
    .typewriter,
    .cta,
    .scroll-hint {
      animation: none;
      opacity: 1;
      transform: none;
    }

    .typewriter-cursor,
    .scroll-line::after {
      animation: none;
    }
  }
</style>

<script>
  // Particle background
  const canvas = document.getElementById("particles") as HTMLCanvasElement | null;
  if (canvas) {
    const reduced = matchMedia("(prefers-reduced-motion: reduce)").matches;
    const ctx = canvas.getContext("2d");

    if (ctx && !reduced) {
      type P = { x: number; y: number; vx: number; vy: number; r: number };
      let particles: P[] = [];
      let width = 0;
      let height = 0;
      let dpr = 1;
      const mouse = { x: -9999, y: -9999, active: false };

      const init = () => {
        const area = width * height;
        const count = Math.min(90, Math.max(28, Math.floor(area / 16000)));
        particles = Array.from({ length: count }, () => ({
          x: Math.random() * width,
          y: Math.random() * height,
          vx: (Math.random() - 0.5) * 0.28,
          vy: (Math.random() - 0.5) * 0.28,
          r: 0.8 + Math.random() * 1.6,
        }));
      };

      const resize = () => {
        dpr = Math.min(window.devicePixelRatio || 1, 2);
        width = canvas.clientWidth;
        height = canvas.clientHeight;
        canvas.width = Math.floor(width * dpr);
        canvas.height = Math.floor(height * dpr);
        ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
        init();
      };

      const step = () => {
        ctx.clearRect(0, 0, width, height);

        for (const p of particles) {
          p.x += p.vx;
          p.y += p.vy;
          if (p.x < 0 || p.x > width) p.vx *= -1;
          if (p.y < 0 || p.y > height) p.vy *= -1;

          if (mouse.active) {
            const dx = p.x - mouse.x;
            const dy = p.y - mouse.y;
            const dist = Math.hypot(dx, dy);
            if (dist > 0 && dist < 140) {
              const force = ((140 - dist) / 140) * 0.6;
              p.x += (dx / dist) * force;
              p.y += (dy / dist) * force;
            }
          }
        }

        for (let i = 0; i < particles.length; i++) {
          for (let j = i + 1; j < particles.length; j++) {
            const a = particles[i];
            const b = particles[j];
            const dx = a.x - b.x;
            const dy = a.y - b.y;
            const d = Math.hypot(dx, dy);
            if (d < 130) {
              const op = (1 - d / 130) * 0.18;
              ctx.strokeStyle = `rgba(17,17,17,${op})`;
              ctx.lineWidth = 0.6;
              ctx.beginPath();
              ctx.moveTo(a.x, a.y);
              ctx.lineTo(b.x, b.y);
              ctx.stroke();
            }
          }
        }

        ctx.fillStyle = "rgba(17,17,17,0.45)";
        for (const p of particles) {
          ctx.beginPath();
          ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
          ctx.fill();
        }

        requestAnimationFrame(step);
      };

      window.addEventListener("resize", resize);
      window.addEventListener("mousemove", (e) => {
        const rect = canvas.getBoundingClientRect();
        mouse.x = e.clientX - rect.left;
        mouse.y = e.clientY - rect.top;
        mouse.active = true;
      });
      window.addEventListener("mouseleave", () => {
        mouse.active = false;
      });

      resize();
      step();
    }
  }

  // Typewriter intro
  const tw = document.getElementById("typewriter");
  const linesNode = document.getElementById("intro-lines");
  if (tw && linesNode) {
    const reduced = matchMedia("(prefers-reduced-motion: reduce)").matches;
    let lines: string[] = [];
    try {
      lines = JSON.parse(linesNode.textContent || "[]");
    } catch {
      lines = [];
    }

    if (reduced) {
      tw.textContent = lines.join("  ");
    } else if (lines.length > 0) {
      const wait = (ms: number) => new Promise((r) => setTimeout(r, ms));
      const TYPE_MS = 90;
      const ERASE_MS = 35;
      const HOLD_AFTER_TYPE = 1800;
      const HOLD_AFTER_ERASE = 220;

      (async () => {
        let idx = 0;
        while (true) {
          const s = lines[idx];
          for (let i = 1; i <= s.length; i++) {
            tw.textContent = s.slice(0, i);
            await wait(TYPE_MS);
          }
          await wait(HOLD_AFTER_TYPE);
          for (let i = s.length; i >= 0; i--) {
            tw.textContent = s.slice(0, i);
            await wait(ERASE_MS);
          }
          await wait(HOLD_AFTER_ERASE);
          idx = (idx + 1) % lines.length;
        }
      })();
    }
  }
</script>
