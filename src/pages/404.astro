---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="页面不存在">
  <section class="page-title">
    <p class="eyebrow">404</p>
    <h1>页面不存在</h1>
    <p class="lead">你访问的页面不存在，或者已经移动到其他位置。</p>
    <div class="button-row">
      <a class="button primary" href="/">返回主页</a>
      <a class="button" href="/blog/">查看 Blog</a>
    </div>
  </section>
</BaseLayout>
