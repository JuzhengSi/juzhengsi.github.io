---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { publications } from "../../data/publications";
import { site } from "../../data/site";

const featuredPublications = publications.slice(0, 3);
---

<BaseLayout title="简历" description="司居正个人简历，包含教育、科研、项目与论文经历。">
  <div class="jp">
    <section class="intro">
      <p class="kicker">CS · AI · LLM</p>
      <h1 class="name">司居正</h1>
      <p class="name-romaji">SI JUZHENG</p>

      <div class="rule-double" aria-hidden="true"></div>

      <p class="lead">
        我本科就读于山东大学软件工程专业，硕士阶段即将就读于哈尔滨工业大学计算机技术方向。目前的研究方向聚焦于大模型、复杂自然语言指令下的多智能体系统等。
      </p>

      <dl class="meta-grid">
        <div>
          <dt>邮箱</dt>
          <dd><a href={`mailto:${site.email}`}>{site.email}</a></dd>
        </div>
        <div>
          <dt>GitHub</dt>
          <dd><a href={site.github} target="_blank" rel="noopener">github.com/JuzhengSi</a></dd>
        </div>
        <div>
          <dt>学校</dt>
          <dd>山东大学 / 哈尔滨工业大学</dd>
        </div>
      </dl>
    </section>

    <section class="block" aria-labelledby="education">
      <header class="block-head">
        <span class="block-num">壹</span>
        <h2 id="education">教育経歴</h2>
        <span class="block-en">Education</span>
      </header>
      <dl class="row-list">
        <div class="row">
          <dt class="row-date">2022 — 2026</dt>
          <dd class="row-body">
            <strong>山东大学</strong><span class="row-sep">／</span><span class="row-sub">软件工程，学士</span>
          </dd>
        </div>
        <div class="row">
          <dt class="row-date">2026 — 2029</dt>
          <dd class="row-body">
            <strong>哈尔滨工业大学</strong><span class="row-sep">／</span><span class="row-sub">计算机技术，硕士</span>
          </dd>
        </div>
      </dl>
    </section>

    <section class="block" aria-labelledby="research">
      <header class="block-head">
        <span class="block-num">貳</span>
        <h2 id="research">研究経歴</h2>
        <span class="block-en">Research</span>
      </header>
      <h3>广东省人工智能实验室（深圳）／ 心理大模型相关研究</h3>
      <ul>
        <li>负责领域数据收集与清洗，参与真实心理咨询场景下的数据构建流程。</li>
        <li>主导模型全量微调与参数高效微调，并构建多维指标体系进行综合评估。</li>
        <li>参与心理画像、咨询策略识别、风险等级评估等任务设计，支撑模型理解与生成能力验证。</li>
      </ul>
    </section>

    <section class="block" aria-labelledby="projects">
      <header class="block-head">
        <span class="block-num">參</span>
        <h2 id="projects">主要作品</h2>
        <span class="block-en">Works</span>
      </header>
      <h3>多智能体图像编辑系统</h3>
      <ul>
        <li>构建 Figure Edit Agent，将复杂图像编辑任务拆分为规划、执行、评估与重规划流程。</li>
        <li>设计 Plan、Execute、Evaluator 三类智能体，并通过 ToolRegistry 动态调度图像理解、视觉定位、分割、裁剪、拼接、提示词重写、图像编辑与结果评估等工具。</li>
        <li>抽象编辑与分割后端接口，方便接入不同图像编辑模型和分割模型，降低工具编排流程与具体视觉后端之间的耦合。</li>
        <li>从 harness engineering 角度设计可复现的任务运行与评测框架，统一管理输入样例、工具调用轨迹、候选结果、评估结论与失败原因。</li>
        <li>设计结构化 artifacts、operations 与 JSONL 运行日志，支持失败重试、局部继续、结果回放、跨后端对比和全局重规划，便于问题定位、实验复现与流程回归。</li>
      </ul>
    </section>

    <section class="block" aria-labelledby="publications">
      <header class="block-head">
        <span class="block-num">肆</span>
        <h2 id="publications">論文発表</h2>
        <span class="block-en">Publications</span>
      </header>
      <ol class="pub-list">
        {
          featuredPublications.map((publication) => (
            <li class="pub-item">
              <h3>
                <a href={publication.url} target="_blank" rel="noopener">{publication.title}</a>
              </h3>
              <p class="pub-authors">
                {publication.authors.split("Juzheng Si")[0]}<strong>Juzheng Si</strong>{publication.authors.split("Juzheng Si")[1]}
              </p>
              <p class="pub-meta">{publication.venue} · {publication.year}</p>
            </li>
          ))
        }
      </ol>
    </section>

    <section class="cv-download" aria-label="下载 PDF 简历">
      <a class="download-btn" href="/assets/resume.pdf" target="_blank" rel="noopener">
        <span class="square" aria-hidden="true"></span>
        <span class="download-label">下载 PDF 简历</span>
        <span class="download-arrow" aria-hidden="true">↓</span>
      </a>
    </section>
  </div>
</BaseLayout>

<style>
  .jp {
    --ink: #111111;
    --ink-soft: #2a2a2a;
    --gray: #6e6c66;
    --mute: #9a958c;
    --hair: #cfcdc3;
    --hair-soft: #e3e1d6;
    --serif:
      "Source Han Serif SC", "Noto Serif CJK SC", "Noto Serif SC", "Songti SC", "STSong",
      "Yu Mincho", "YuMincho", "Hiragino Mincho ProN", "Times New Roman", serif;
    --sans:
      "Inter", ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      "PingFang SC", "Microsoft YaHei", sans-serif;
    color: var(--ink);
    font-family: var(--serif);
  }

  .jp .intro {
    padding: 24px 0 56px;
  }

  .jp .kicker {
    margin: 0 0 18px;
    color: var(--gray);
    font-family: var(--sans);
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .jp .name {
    margin: 0;
    font-family: var(--serif);
    font-weight: 600;
    font-size: clamp(2rem, 3.6vw, 3rem);
    line-height: 1.15;
    letter-spacing: 0.06em;
    color: var(--ink);
    white-space: nowrap;
  }

  .jp .name-romaji {
    margin: 10px 0 0;
    color: var(--gray);
    font-family: var(--sans);
    font-size: 0.78rem;
    font-weight: 400;
    letter-spacing: 0.24em;
    text-transform: uppercase;
  }

  .jp .rule-double {
    height: 4px;
    width: 56px;
    margin: 24px 0 22px;
    border-top: 1px solid var(--ink);
    border-bottom: 1px solid var(--ink);
  }

  .jp .lead {
    max-width: 36em;
    margin: 0;
    color: var(--ink-soft);
    font-family: var(--serif);
    font-size: 1.04rem;
    line-height: 1.9;
  }

  .jp .meta-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 12px 48px;
    margin: 36px 0 0;
    padding: 22px 0 0;
    border-top: 1px solid var(--hair);
  }

  .jp .meta-grid > div {
    min-width: 0;
  }

  .jp .meta-grid dt {
    margin: 0 0 4px;
    color: var(--mute);
    font-family: var(--sans);
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .jp .meta-grid dd {
    margin: 0;
    font-family: var(--serif);
    font-size: 0.96rem;
    color: var(--ink);
    line-height: 1.55;
  }

  .jp .meta-grid dd a {
    color: inherit;
    text-decoration: none;
    border-bottom: 1px solid var(--hair);
    padding-bottom: 1px;
    transition: border-color 0.15s ease;
  }

  .jp .meta-grid dd a:hover {
    border-bottom-color: var(--ink);
  }

  .jp .block {
    padding: 48px 0;
    border-top: 1px solid var(--ink);
    position: relative;
  }

  .jp .block::before {
    content: "";
    position: absolute;
    top: 4px;
    left: 0;
    right: 0;
    border-top: 1px solid var(--hair-soft);
  }

  .jp .block-head {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 16px;
    margin-bottom: 24px;
  }

  .jp .block-num {
    font-family: var(--serif);
    font-size: 1.3rem;
    font-weight: 500;
    color: var(--ink);
  }

  .jp .block-head h2 {
    margin: 0;
    font-family: var(--serif);
    font-size: clamp(1.3rem, 2vw, 1.6rem);
    font-weight: 500;
    letter-spacing: 0.08em;
    color: var(--ink);
  }

  .jp .block-en {
    color: var(--mute);
    font-family: var(--sans);
    font-size: 0.74rem;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
  }

  .jp .block h3 {
    margin: 0 0 12px;
    font-family: var(--serif);
    font-size: 1.04rem;
    font-weight: 600;
    color: var(--ink);
  }

  .jp .block ul {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .jp .block ul li {
    position: relative;
    padding-left: 20px;
    margin: 8px 0;
    color: var(--ink-soft);
    line-height: 1.85;
  }

  .jp .block ul li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.85em;
    width: 6px;
    height: 6px;
    background: var(--ink);
  }

  .jp .row-list {
    margin: 0;
    padding: 0;
  }

  .jp .row-list .row {
    display: grid;
    grid-template-columns: 160px 1fr;
    gap: 24px;
    padding: 14px 0;
    border-bottom: 1px solid var(--hair-soft);
    align-items: baseline;
  }

  .jp .row-list .row:first-child {
    border-top: 1px solid var(--hair-soft);
  }

  .jp .row-date {
    margin: 0;
    color: var(--gray);
    font-family: var(--sans);
    font-variant-numeric: tabular-nums;
    font-size: 0.94rem;
  }

  .jp .row-body {
    margin: 0;
    color: var(--ink);
  }

  .jp .row-body strong {
    font-weight: 600;
  }

  .jp .row-sep {
    color: var(--mute);
    margin: 0 8px;
  }

  .jp .row-sub {
    color: var(--ink-soft);
    font-size: 0.94rem;
  }

  .jp .pub-list {
    counter-reset: pub;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .jp .pub-item {
    counter-increment: pub;
    position: relative;
    padding: 20px 0 20px 52px;
    border-top: 1px solid var(--hair-soft);
  }

  .jp .pub-item:last-child {
    border-bottom: 1px solid var(--hair-soft);
  }

  .jp .pub-item::before {
    content: counter(pub, decimal-leading-zero);
    position: absolute;
    left: 0;
    top: 22px;
    color: var(--gray);
    font-family: var(--sans);
    font-size: 0.78rem;
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.12em;
  }

  .jp .pub-item h3 {
    margin: 0 0 6px;
    font-size: 1.02rem;
    font-weight: 600;
    line-height: 1.5;
  }

  .jp .pub-item h3 a {
    color: var(--ink);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color 0.2s ease;
  }

  .jp .pub-item h3 a:hover {
    border-bottom-color: var(--ink);
  }

  .jp .pub-authors {
    margin: 0;
    color: var(--ink-soft);
    font-size: 0.94rem;
    line-height: 1.65;
  }

  .jp .pub-authors strong {
    color: var(--ink);
    font-weight: 600;
  }

  .jp .pub-meta {
    margin: 4px 0 0;
    color: var(--mute);
    font-family: var(--sans);
    font-size: 0.84rem;
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.04em;
  }

  /* CV download button at the bottom */
  .jp .cv-download {
    margin: 64px 0 24px;
    padding: 40px 0;
    border-top: 1px solid var(--ink);
    display: flex;
    justify-content: center;
  }

  .jp .download-btn {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    padding: 16px 28px;
    background: var(--ink);
    color: #f7f7f4;
    font-family: var(--serif);
    font-size: 1rem;
    letter-spacing: 0.08em;
    text-decoration: none;
    border: 1px solid var(--ink);
    transition: background 0.2s ease, color 0.2s ease, transform 0.2s ease;
  }

  .jp .download-btn .square {
    width: 7px;
    height: 7px;
    background: #f7f7f4;
    transition: background 0.2s ease;
  }

  .jp .download-btn .download-arrow {
    font-family: var(--sans);
    font-size: 1.1rem;
    transition: transform 0.25s ease;
  }

  .jp .download-btn:hover {
    background: #f7f7f4;
    color: var(--ink);
  }

  .jp .download-btn:hover .square {
    background: var(--ink);
  }

  .jp .download-btn:hover .download-arrow {
    transform: translateY(3px);
  }

  @media (max-width: 760px) {
    .jp .meta-grid {
      flex-direction: column;
      gap: 14px;
    }

    .jp .block {
      padding: 36px 0;
    }

    .jp .row-list .row {
      grid-template-columns: 1fr;
      gap: 4px;
    }

    .jp .pub-item {
      padding-left: 40px;
    }
  }
</style>
